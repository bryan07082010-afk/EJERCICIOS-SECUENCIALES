Algoritmo ejercicio7_segundos
	definir total_segundos, horas, minutos, segundos como entero 
	
	escribir "ingrese la cantidad de segundos"
	leer total_segundos
	horas = total_segundos mod 3600
	minutos = (total_segundos mod 3600) mod 60
	segundos = total_segundos mod 60
	
	escribir horas,"horas, ", minutos "minutos y ",segundos, " segundos"
FinAlgoritmo
